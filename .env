BENCH_HOST=localhost
BENCH_PORT=5434
BENCH_NAME=benchmark_db
BENCH_USER=postgres
BENCH_PASSWORD=123
BENCH_POSTGRES_DATA_DIR=/var/lib/postgresql/data

# Target Database (to be tuned)
TARGET_DB_HOST=localhost
TARGET_DB_PORT=5433
TARGET_DB_NAME=monitor
TARGET_DB_USER=postgres
TARGET_DB_PASSWORD=123
#TARGET_POSTGRES_CONF_PATH=/var/lib/postgresql/data/postgresql.conf
TARGET_POSTGRES_CONF_PATH=config/postgresql.conf
TARGET_POSTGRES_DATA_DIR=/var/lib/postgresql/data

# TSBS Benchmark Configuration
TSBS_BIN_PATH=/home/ablautova/go/bin
TSBS_WORKERS=4
TSBS_BATCH_SIZE=10000
TSBS_SCALE=100
TSBS_DURATION=300

# Optimization Configuration
OPTIMIZATION_BUDGET=30
INITIAL_SAMPLES=5
ACQUISITION_FUNCTION=EI

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# System Resources
SYSTEM_RAM_GB=32
SYSTEM_CPU_CORES=8
SYSTEM_DISK_TYPE=ssd

RES_DIR=results
QUERIES_DIR=tsbs_data